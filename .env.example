# ─── Blockchain ──────────────────────────────────────────────────────────────
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
CHAIN_ID=11155111
AGENT_PRIVATE_KEY=0xYOUR_AGENT_PRIVATE_KEY
AGENT_ADDRESS=0xYOUR_AGENT_WALLET_ADDRESS
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# ─── Deployed contract addresses (fill after running Deploy.s.sol) ───────────
CONTRACT_ADDRESS=0x
AUDIT_LOG_ADDRESS=0x
POLICY_REGISTRY_ADDRESS=0x
ZK_VERIFIER_ADDRESS=0x

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o

# ─── Infrastructure ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Pipeline ────────────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=300
MIN_DATA_QUALITY_SCORE=0.90
LOG_LEVEL=INFO

# ─── Dashboard ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
